<p style={{ textAlign:“center”, marginTop:“16px”, fontSize:“0.82em”, color: m.textMuted }}>
¿Ya tienes cuenta? <span onClick={() => setModo(“login”)} style={{ color:t.a, cursor:“pointer”, fontWeight:“bold” }}>Ingresa aquí</span>
</p>
