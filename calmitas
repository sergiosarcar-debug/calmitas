// HELPER IA — llama a la API real, fallback offline
// ─────────────────────────────────────────────────────────────

async function callIA(apiMsgs: any[], sysPrompt: string, fallback: string) {
try {
const res = await fetch(“https://api.anthropic.com/v1/messages”, {
method: “POST”,
headers: {
“Content-Type”: “application/json”,
“anthropic-version”: “2023-06-01”,
“anthropic-dangerous-direct-browser-access”: “true”,
},
body: JSON.stringify({
model: “claude-haiku-4-5-20251001”,
max_tokens: 380,
system: sysPrompt,
messages: apiMsgs,
}),
});
if (res.ok) {
const d = await res.json();
const txt = d.content?.[0]?.text;
return txt || fallback;
}
} catch {}
return fallback;
}

