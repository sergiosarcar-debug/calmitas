function JuegoMemoria({ t, onBack, onRecompensa }: any) {
const m = useM();
const EMOJIS_PARES = [“🌸”,“🎵”,“⭐”,“🌈”,“🦋”,“🍀”,“🌙”,“🎨”];
const yaInsignia = useRef(false);

const generarTablero = () => {
const pares = […EMOJIS_PARES,…EMOJIS_PARES].map((e,i)=>({id:i,e,v:false,f:false}));
for (let i=pares.length-1;i>0;i–) { const j=Math.floor(Math.random()*(i+1)); [pares[i],pares[j]]=[pares[j],pares[i]]; }
return pares;
};

const [cartas, setCartas] = useState(generarTablero);
const [seleccionadas, setSeleccionadas] = useState([] as number[]);
const [intentos, setIntentos] = useState(0);
const [ganado, setGanado] = useState(false);
const [bloqueado, setBloqueado] = useState(false);

const tocar = (i: number) => {
if (bloqueado||cartas[i].v||cartas[i].f) return;
const nc=[…cartas]; nc[i]={…nc[i],v:true};
const ns=[…seleccionadas,i]; setCartas(nc); setSeleccionadas(ns);
if (ns.length===2) {
setIntentos(x=>x+1); setBloqueado(true);
if (nc[ns[0]].e===nc[ns[1]].e) {
const mm=[…nc]; mm[ns[0]]={…mm[ns[0]],f:true}; mm[ns[1]]={…mm[ns[1]],f:true};
setCartas(mm); setSeleccionadas([]); setBloqueado(false);
if (mm.every(x=>x.f)) { setGanado(true); if(!yaInsignia.current){yaInsignia.current=true;onRecompensa(“memorion”);} }
} else {
setTimeout(() => { setCartas(x=>x.map((c,idx)=>ns.includes(idx)?{…c,v:false}:c)); setSeleccionadas([]); setBloqueado(false); },900);
}
}
};

const reiniciar = () => { yaInsignia.current=false; setCartas(generarTablero()); setSeleccionadas([]); setIntentos(0); setGanado(false); setBloqueado(false); };

return (
<div style={{ maxWidth:“400px”, width:“100%” }}>
<BackBtn onClick={onBack} />
<div style={{ display:“flex”, justifyContent:“space-between”, alignItems:“flex-start”, marginBottom:“12px” }}>
<PageTitle sub="Encuentra todos los pares">🧠 Memoria</PageTitle>
<Card style={{ padding:“8px 12px”, textAlign:“center”, flexShrink:0, marginLeft:“10px” }}>
<div style={{ fontSize:“1.1em”, fontWeight:“900”, color:t.a }}>{intentos}</div>
<div style={{ fontSize:“0.6em”, color: m.textFaint }}>intentos</div>
</Card>
</div>
{ganado && (
<Card style={{ marginBottom:“14px”, background:“rgba(52,211,153,0.1)”, textAlign:“center”, padding:“20px” }}>
<div style={{ fontSize:“3em”, marginBottom:“8px” }}>🎉</div>
<p style={{ margin:“0 0 12px”, fontWeight:“bold”, color:”#34d399” }}>¡Completado en {intentos} intentos! 🏅</p>
<Btn onClick={reiniciar} t={t}>Jugar de nuevo</Btn>
</Card>
)}
<div style={{ display:“grid”, gridTemplateColumns:“repeat(4,1fr)”, gap:“8px” }}>
{cartas.map((x,i)=>(
<div key={x.id} onClick={() => tocar(i)}
style={{ aspectRatio:“1”, borderRadius:“12px”, display:“flex”, alignItems:“center”, justifyContent:“center”,
fontSize:“1.6em”, cursor: x.f?“default”:“pointer”,
background: x.f?`${t.a}33`:x.v?m.surfaceHover:m.surface,
border: x.f?`1px solid ${t.a}55`:x.v?`1px solid ${m.surfaceBorder}`:m.gameBorder?`1px solid ${m.gameBorder}`:`1px solid ${m.surfaceBorder}`,
transition:“all 0.2s” }}>
{x.v||x.f?x.e:“🔒”}
