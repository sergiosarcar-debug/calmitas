function Respiracion({ t, onBack, onRecompensa }: any) {
const m = useM();
const FASES = [{n:“Inhala”,d:4},{n:“Mantén”,d:7},{n:“Exhala”,d:8}];
const COLORES_FASE = [t.b,t.a,”#34d399”];
