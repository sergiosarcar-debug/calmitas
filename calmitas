const handleLogin = (email: string, accData: any) => {
if (email===”**invitado**”) {
const gs = initUserState({email:”**invitado**”});
gs.perfil={nombre:“Visitante”,edad:20,ciclo:“3er”,trabaja:false,causas:[1,4],avatar:“🧒”,email:”**invitado**”};
(gs as any).orgUni={cursos:[],horario:[],tareas:[],diasClase:[1,2,3,4,5],turno:“manana”,mismoHorario:true,horaGlobal:{ini:“08:00”,fin:“13:00”},horarioPorDia:{},horarioConfigurado:true};
setEsInvitado(true); setEmailActivo(”**invitado**”); setFullState(gs); setFase(“app”); return;
}
setEsInvitado(false); setEmailActivo(email);
const loaded = initUserState({…accData,email}); setFullState(loaded);
if (!loaded.perfil) setFase(“perfil”);
else setFase(“app”);
};

const handlePerfilDone = (perfil: any) => {
const newState = {…fullState,perfil,email:emailActivo}; setFullState(newState);
const pwd = getAccount(emailActivo)?.password;
saveAccount(emailActivo,{…newState,password:pwd}); setFase(“app”);
};

const handleHorarioDone = (horarioData: any) => {
const orgBase = fullState.orgUni||{cursos:[],horario:[],tareas:[]};
const cursosMerged = horarioData.cursos?.length>0 ? horarioData.cursos : (orgBase.cursos||[]);
const newOrgUni = {…orgBase,diasClase:horarioData.diasClase,turno:horarioData.turno,
mismoHorario:horarioData.mismoHorario,horaGlobal:horarioData.horaGlobal,
horarioPorDia:horarioData.horarioPorDia,horarioConfigurado:true,
cursos:cursosMerged,horario:orgBase.horario||[],tareas:orgBase.tareas||[]};
const newState = {…fullState,orgUni:newOrgUni}; setFullState(newState);
if (emailActivo!==”**invitado**”) {
const pwd = getAccount(emailActivo)?.password;
saveAccount(emailActivo,{…newState,password:pwd});
}
setFase(“app”);
};

const realDispatch = useCallback((action: any) => {
if (esInvitado) { setFullState((prev: any) => prev?appReducer(prev,action):prev); return; }
setFullState((prev: any) => {
if (!prev) return prev;
const next = appReducer(prev,action);
const pwd = getAccount(emailActivo)?.password;
saveAccount(emailActivo,{…next,password:pwd});
return next;
});
},[emailActivo,esInvitado]);

/** Toggle modo claro/oscuro */
const handleToggleModo = useCallback(() => {
realDispatch({type:“SET_MODO”,dark:!(fullState?.modoOscuro??true)});
},[fullState,realDispatch]);

const onRecompensa = useCallback((id: string) => {
if (!fullState||fullState.insignias.includes(id)) return;
const ins = INSIGNIAS_DB.find(x=>x.id===id);
if (ins&&!esInvitado) setPopup(ins);
realDispatch({type:“ADD_INSIGNIA”,id});
},[fullState,realDispatch,esInvitado]);

const onNav = useCallback((id: string) => {
if (id===“configuracion_tab”) { setTab(“configuracion”); setSub(null); return; }
if (id===“insignias_tab”)     { setTab(“insignias”);     setSub(null); return; }
setSub(id);
},[]);

const onCerrar = () => { setFase(“auth”); setFullState(null); setEmailActivo(””); setEsInvitado(false); setSub(null); setTab(“menu”); setPopup(null); };

if (fase===“cargando”) return (
<div style={{ minHeight:“100vh”, background:”#0f0c29”, display:“flex”, alignItems:“center”, justifyContent:“center” }}>
<div style={{ fontSize:“3em” }}>🤲</div>
</div>
);

const renderSub = () => {
