<span style={{ color:t.a, fontSize:“0.74em”, fontWeight:“bold” }}>{prog}%</span>
</div>
<div style={{ background: m.progressBg, borderRadius:“10px”, height:“5px” }}>
<div style={{ background:`linear-gradient(90deg,${t.a},${t.b})`, borderRadius:“10px”, height:“5px”, width:`${prog}%`, transition:“width 0.35s ease” }} />
</div>
<div style={{ display:“flex”, justifyContent:“space-between”, marginTop:“5px” }}>
{[“Nombre”,“Edad”,“Ciclo”,“Trabajo”,“Estrés”,“Avatar”].map((l,i) => (
<span key={i} style={{ fontSize:“0.62em”, color: paso>i ? t.a : m.textVeryFaint, fontWeight: paso===i+1 ? “bold” : “normal” }}>{l}</span>
))}
</div>
</div>

