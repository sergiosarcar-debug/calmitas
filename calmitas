{curso?(curso as any).sigla||(curso as any).nombre.substring(0,4):””}
</div>
</td>
);
})}
</tr>
))}
</tbody>
</table>
</div>
{bloqueEdit && (
<div style={{ position:“fixed”, inset:0, background:“rgba(0,0,0,0.75)”, display:“flex”, alignItems:“flex-end”, justifyContent:“center”, zIndex:500, padding:“20px” }}>
<Card style={{ width:“100%”, maxWidth:“400px”, padding:“20px” }}>
<p style={{ margin:“0 0 14px”, fontWeight:“bold”, fontSize:“0.92em”, color: m.text }}>{DIAS_FULL[bloqueEdit.dia]} · {bloqueEdit.hora}</p>
<div style={{ display:“flex”, flexDirection:“column”, gap:“8px”, marginBottom:“14px” }}>
<div onClick={() => { setBloque(bloqueEdit.dia,bloqueEdit.hora,null); setBloqueEdit(null); }}
style={{ background: m.surface, border:`1px solid ${m.surfaceBorder}`, borderRadius:“12px”, padding:“12px”, cursor:“pointer”, fontSize:“0.85em”, color: m.textMuted }}>🚫 Vaciar bloque</div>
{org.cursos.map((c: any) => (
<div key={c.id} onClick={() => { setBloque(bloqueEdit.dia,bloqueEdit.hora,c.id); setBloqueEdit(null); }}
style={{ background:`${c.color}22`, border:`1px solid ${c.color}44`, borderRadius:“12px”, padding:“12px”, cursor:“pointer”, display:“flex”, alignItems:“center”, gap:“10px” }}>
