else setTimeout(()=>setSub(id),50);
}} />;
if (sub===“calmitas”)      return <Calmitas {…base} />;
if (sub===“burbujas”)      return <Burbujas t={t} onBack={()=>setSub(null)} onRecompensa={onRecompensa} />;
if (sub===“cazaestres”)    return <CazaEstres t={t} onBack={()=>setSub(null)} onRecompensa={onRecompensa} />;
if (sub===“memoria”)       return <JuegoMemoria t={t} onBack={()=>setSub(null)} onRecompensa={onRecompensa} />;
if (sub===“respiracion”)   return <Respiracion t={t} onBack={()=>setSub(null)} onRecompensa={onRecompensa} />;
if (sub===“sobrecarga”)      return <SobrecargaAcademica t={t} perfil={fullState.perfil} onBack={()=>setSub(null)} onNav={(id:string)=>{setSub(null);setTimeout(()=>setSub(id),50);}} />;
if (sub===“trabajo_estudio”) return <TrabajoEstudio      t={t} perfil={fullState.perfil} onBack={()=>setSub(null)} onNav={(id:string)=>{setSub(null);setTimeout(()=>setSub(id),50);}} />;
if (sub===“dificultad”)      return <DificultadCursos    t={t} perfil={fullState.perfil} onBack={()=>setSub(null)} onNav={(id:string)=>{setSub(null);setTimeout(()=>setSub(id),50);}} />;
if (sub===“presion_notas”)   return <PresionNotas        t={t} perfil={fullState.perfil} onBack={()=>setSub(null)} onNav={(id:string)=>{setSub(null);setTimeout(()=>setSub(id),50);}} />;
if (sub===“estres_grupal”)   return <EstresGrupal        t={t} perfil={fullState.perfil} onBack={()=>setSub(null)} onNav={(id:string)=>{setSub(null);setTimeout(()=>setSub(id),50);}} />;
if (sub===“vulnerabilidad”)  return <VulnerabilidadEmocional t={t} perfil={fullState.perfil} onBack={()=>setSub(null)} onNav={(id:string)=>{setSub(null);setTimeout(()=>setSub(id),50);}} />;
if (sub===“frases”)        return <Frases perfil={fullState.perfil} t={t} onBack={()=>setSub(null)} />;
if (sub===“recordatorios”) return <Recordatorios t={t} onBack={()=>setSub(null)} />;
if (sub===“plan”)          return <PlanDia t={t} onBack={()=>setSub(null)} perfil={fullState.perfil} />;
if (sub===“trayecto”)      return <RutinaTrayecto t={t} onBack={()=>setSub(null)} onNav={(id: string) => { setSub(null); setTimeout(()=>setSub(id),50); }} />;
if (sub===“ia_psico” || (typeof sub === “object” && sub?.id===“ia_psico”))
return <HablaConCalmitas t={t} onBack={()=>setSub(null)} perfil={fullState.perfil}
nivelEstres={typeof sub === “object” ? sub?.nivel : null}
contextoEstres={typeof sub === “object” && sub?.donde !== undefined ? sub : null} />;
if (sub===“org_uni”)       return <OrgUni state={fullState} dispatch={realDispatch} t={t} onBack={()=>setSub(null)} onRecompensa={onRecompensa} />;
if (sub===“horario_edit”)  return (
<div style={{ maxWidth:“420px”, width:“100%”, paddingBottom:“0” }}>
<BackBtn onClick={()=>setSub(null)} />
<PageTitle sub="Actualiza tus días, horas y cursos">📅 Editar horario de clases</PageTitle>
<RegistroHorario onDone={(data: any) => { handleHorarioDone(data); setSub(null); }} t={t} perfil={fullState.perfil} />
</div>
);
return null;
};

const renderTab = () => {
if (!fullState) return null;
if (tab===“menu”)          return <Menu state={fullState} t={t} onNav={onNav} esInvitado={esInvitado} onRegistrarse={()=>setFase(“auth”)} onToggleModo={handleToggleModo} />;
if (tab===“horario”)       return <TabHorario state={fullState} dispatch={realDispatch} t={t} />;
if (tab===“juegos”)        return <TabJuegos state={fullState} t={t} onNav={onNav} />;
if (tab===“org_uni”)       return <OrgUni state={fullState} dispatch={realDispatch} t={t} onBack={()=>setTab(“menu”)} onRecompensa={onRecompensa} />;
if (tab===“historial”)     return <Historial state={fullState} esInvitado={esInvitado} onRegistrarse={()=>setFase(“auth”)} />;
if (tab===“insignias”)     return <Insignias state={fullState} t={t} />;
if (tab===“configuracion”) return <Configuracion state={fullState} dispatch={realDispatch} t={t} onNav={onNav} onCerrar={onCerrar} esInvitado={esInvitado} onRegistrarse={()=>setFase(“auth”)} onToggleModo={handleToggleModo} />;
return null;
};

return (
