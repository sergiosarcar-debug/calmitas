const [sz, setSz] = useState(130);
const iv = useRef(null as any);
const yaDioBadge = useRef(false);

useEffect(() => {
if (!run) { clearInterval(iv.current); return; }
setSeg(FASES[fi].d); setSz(fi===2?120:185);
iv.current = setInterval(() => {
setSeg(s => {
if (s<=1) {
clearInterval(iv.current);
const next=(fi+1)%3; setFi(next);
if (next===0) setCiclos(c => { const nc=c+1; if (nc>=3&&!yaDioBadge.current){yaDioBadge.current=true;onRecompensa(“respirador”);} return nc; });
return FASES[next].d;
}
return s-1;
});
},1000);
return () => clearInterval(iv.current);
},[run,fi]); // eslint-disable-line

return (
