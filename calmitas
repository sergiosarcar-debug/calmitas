}

function RegistroPerfil({ email, onDone, t }: any) {
const m = useM();
const TOTAL = 6;
const [paso, setPaso] = useState(1);
const [form, setForm] = useState({ nombre:””, edad:””, ciclo:””, trabaja:null as any, causas:[] as number[], avatar:“🧑” });
const [err,  setErr]  = useState(””);

const set = (k: string, v: any) => { setForm(f => ({ …f, [k]: v })); setErr(””); };
const toggleCausa = (id: number) => setForm(f => ({ …f, causas: f.causas.includes(id) ? f.causas.filter(c => c !== id) : […f.causas, id] }));

const validar = () => {
if (paso===1 && !form.nombre.trim()) return “Ingresa tu nombre”;
if (paso===2 && (!form.edad || isNaN(+form.edad) || +form.edad<15 || +form.edad>60)) return “Ingresa una edad válida (15–60)”;
if (paso===3 && !form.ciclo) return “Selecciona tu ciclo”;
if (paso===4 && form.trabaja===null) return “Selecciona una opción”;
if (paso===5 && form.causas.length===0) return “Selecciona al menos una causa”;
return “”;
};

const siguiente = () => {
const e = validar(); if (e) { setErr(e); return; } setErr(””);
if (paso < TOTAL) setPaso(paso+1); else onDone({ …form, email });
};

const prog = Math.round((paso/TOTAL)*100);

return (
<div style={{ maxWidth:“400px”, width:“100%” }}>
<div style={{ marginBottom:“20px” }}>
