// ─────────────────────────────────────────────────────────────
// MOTOR DE RESPUESTAS IA — sin API key, siempre funciona
// ─────────────────────────────────────────────────────────────

function generarRespuestaCalmitas(texto: string, historial: any[], perfil: any, ctx: any): string {
const t = texto.toLowerCase();
const nombre = perfil?.nombre ? `, ${perfil.nombre}` : “”;
const turno  = historial.length;

// ── Señales de crisis → siempre prioridad máxima
const crisis = [“no quiero vivir”,“hacerme daño”,“suicidar”,“quitarme la vida”,“ya no quiero seguir”,“desaparecer”,“morir”];
if (crisis.some(c => t.includes(c))) {
return `Gracias por contarme esto${nombre}. Lo que sientes es muy importante y quiero que sepas que no estás solo/a 💙\n\nPor favor habla ahora con alguien de confianza o llama a la Línea de la Vida: 0800-4-1212 (gratuita, 24h). Están ahí para acompañarte en este momento.`;
}

// ── Respuestas al primer mensaje con contexto del medidor
if (turno === 0 && ctx) {
const { nivel } = ctx;
if (nivel >= 8) return `Eso es mucho estrés encima${nombre} 🔴 Antes de hablar, necesito que hagas algo: toma 3 respiraciones lentas ahora mismo. Inhala 4 segundos, mantén 4, exhala 4.\n\n¿Puedes hacer eso? Después cuéntame qué está pasando.`;
if (nivel >= 6) return `Entiendo que estás con bastante carga${nombre} 🟠 El estrés acumulado es real y no lo estás inventando.\n\nCuéntame — ¿qué es lo que más te está pesando ahora mismo?`;
if (nivel >= 4) return `Hay algo que te está inquietando${nombre} 🟡 No tiene que ser grave para que valga la pena hablarlo.\n\n¿Qué está pasando?`;
return `Me alegra que estés bien${nombre} 🟢 A veces hablar ayuda aunque el nivel sea bajo.\n\n¿Qué tienes en mente?`;
}

// ── Por tema detectado en el mensaje

// Examen / estudio
if (/examen|parcial|final|prueba|nota|reprobar|jalar/.test(t)) {
const respuestas = [
`El miedo al examen es muy normal${nombre}. El cerebro lo interpreta como amenaza aunque no lo sea. 🧠\n\nDime — ¿el examen es pronto o todavía tienes tiempo para prepararte?`,
`Reprobar un examen se siente terrible, pero no define quién eres ni adónde vas${nombre}. Lo que importa es qué haces después.\n\n¿Qué pasó exactamente?`,
`Ese estrés pre-examen tiene solución. La clave no es estudiar más horas, es estudiar mejor en las que tienes.\n\n¿Cuánto tiempo te queda?`,
];
return respuestas[turno % respuestas.length];
}

// Trabajo
if (/trabajo|jefe|turno|horario|sueldo|plata|dinero|necesito trabajar/.test(t)) {
return `Trabajar y estudiar al mismo tiempo es un esfuerzo enorme${nombre}. No todo el mundo puede hacerlo y tú lo estás haciendo 💪\n\n¿El problema es el tiempo, el cansancio, o algo más específico?`;
}

// Familia / casa
if (/familia|mamá|papá|mama|papa|casa|padres|hermano|hermana/.test(t)) {
return `Lo que pasa en casa afecta todo lo demás${nombre}. Es difícil rendir cuando hay tensión en el entorno donde vives.\n\nNo tienes que resolverlo todo solo/a. ¿Qué está pasando con tu familia?`;
}

// Organización / tiempo
if (/tiempo|organizar|todo junto|no puedo con todo|muchas cosas|no me alcanza|planificar/.test(t)) {
return `Cuando hay demasiado encima${nombre}, el cerebro entra en modo parálisis — sientes que no avanzas aunque hagas cosas.\n\nEl primer paso es sacar todo de la cabeza y ordenarlo. ¿Quieres que te ayude a priorizar lo de hoy?`;
}

// Soledad / aislamiento
if (/solo|sola|nadie|no tengo amigos|me siento aislado|ignorado|incomprendido/.test(t)) {
return `Sentirse solo/a en medio de tanta gente es una de las cosas más difíciles${nombre}. Y en la universidad pasa mucho más de lo que se habla.\n\nNo estás raro/a por sentirte así. ¿Desde cuándo lo sientes?`;
}

// Agotamiento / cansancio
if (/cansado|cansada|agotado|agotada|sin energía|no puedo más|rendido|rendida/.test(t)) {
return `El cansancio profundo no se cura solo durmiendo${nombre}. Hay que parar genuinamente, no solo cambiar de actividad.\n\n¿Tu cuerpo te está pidiendo descanso o es algo más que físico?`;
}

// Ansiedad / nervios
if (/ansioso|ansiosa|ansiedad|nervios|angustia|no puedo respirar|taquicardia|me tiembla/.test(t)) {
return `Lo que describes suena a que tu cuerpo está en modo alerta${nombre}. Eso es físicamente real — no es exagerado.\n\nPrimero lo físico: ¿puedes ir a un lugar tranquilo ahora mismo y hacer 3 respiraciones lentas? Después seguimos.`;
}

// Tristeza / llorar
if (/triste|tristeza|llorar|lloro|deprimido|deprimida|vacío|vacía/.test(t)) {
return `Que estés hablando de esto ya es un paso importante${nombre} 💙 La tristeza no siempre tiene un motivo claro y eso también es válido.\n\n¿Hace cuánto te sientes así?`;
}

// Gratitud / mejora
if (/gracias|mejor|bien|ayudaste|funcionó|me siento|más tranquilo|más tranquila/.test(t)) {
const respuestas = [
`Me alegra mucho${nombre} 🌿 Recuerda que este espacio siempre está disponible cuando lo necesites.`,
`Eso es lo que necesitaba escuchar${nombre} ✨ Pequeños pasos también cuentan.`,
`Qué bueno${nombre}. Sigue así — estás manejando esto bien 💪`,
];
return respuestas[turno % respuestas.length];
}

// Respuestas genéricas de acompañamiento según turno de conversación
const genericas = [
`Cuéntame más${nombre}. ¿Qué es lo que más te pesa de eso?`,
`Entiendo${nombre}. ¿Desde cuándo te sientes así?`,
`Eso suena difícil de cargar solo/a${nombre}. ¿Tienes a alguien con quien hablar de esto en tu vida?`,
`Gracias por contarme${nombre}. ¿Qué crees que necesitarías ahora mismo para sentirte un poco mejor?`,
`A veces solo poner en palabras lo que sentimos ya alivia${nombre}. ¿Hay algo concreto en lo que te pueda ayudar — organizar tu día, respirar, o simplemente seguir hablando?`,
`Lo que describes tiene sentido dado todo lo que llevas encima${nombre}. No estás exagerando.\n\n¿Qué paso pequeño podrías dar hoy?`,
];

return genericas[Math.min(turno, genericas.length - 1)];
}

