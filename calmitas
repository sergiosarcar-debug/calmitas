<Input placeholder=“Crea una contraseña” value={form.pass} onChange={(e: any) => setField(“pass”, e.target.value)} type=“password” /></div>
<div><p style={{ margin:“0 0 6px”, fontSize:“0.8em”, color: m.textMuted }}>Confirmar contraseña</p>
<Input placeholder=“Repite tu contraseña” value={form.pass2} onChange={(e: any) => setField(“pass2”, e.target.value)} type=“password” /></div>
