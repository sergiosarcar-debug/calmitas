function RegistroHorario({ onDone, t, perfil }: any) {
const m = useM();
const DIAS_CONFIG = [
{id:1,label:“Lunes”,short:“Lun”},{id:2,label:“Martes”,short:“Mar”},
{id:3,label:“Miércoles”,short:“Mié”},{id:4,label:“Jueves”,short:“Jue”},
{id:5,label:“Viernes”,short:“Vie”},{id:6,label:“Sábado”,short:“Sáb”},
];
const HORAS = [“06:00”,“07:00”,“07:30”,“08:00”,“08:30”,“09:00”,“09:30”,“10:00”,“10:30”,“11:00”,
“11:30”,“12:00”,“12:30”,“13:00”,“13:30”,“14:00”,“14:30”,“15:00”,“15:30”,“16:00”,
“16:30”,“17:00”,“17:30”,“18:00”,“18:30”,“19:00”,“19:30”,“20:00”,“20:30”,“21:00”,“21:30”,“22:00”];
const COLORES = [”#a78bfa”,”#60a5fa”,”#34d399”,”#f59e0b”,”#f472b6”,”#fb923c”,”#38bdf8”,”#818cf8”,”#4ade80”,”#e879f9”];

const [paso, setPaso] = useState(1);
const [diasSel, setDiasSel] = useState([1,2,3,4,5]);
const [mismoHorario, setMismoHorario] = useState(true);
const [horaGlobal, setHoraGlobal] = useState({ ini:“08:00”, fin:“13:00” });
const [horPorDia, setHorPorDia] = useState(Object.fromEntries([1,2,3,4,5,6].map(d=>[d,{ini:“08:00”,fin:“13:00”}])));
const [cursos, setCursos] = useState([] as any[]);
const [nuevoCurso, setNuevoCurso] = useState({ nombre:””, color:”#a78bfa” });
const [err, setErr] = useState(””);

const toggleDia = (id: number) => setDiasSel(d => d.includes(id) ? d.filter(x=>x!==id) : […d,id].sort((a,b)=>a-b));
const updDia = (d: number, campo: string, val: string) => setHorPorDia(h => ({…h,[d]:{…h[d],[campo]:val}}));
const getTurno = (ini: string) => { const h=parseInt(ini); return h<13?“manana”:h<18?“tarde”:“noche”; };
const getHEfectivo = (dia: number) => mismoHorario ? horaGlobal : (horPorDia[dia] || horaGlobal);

const addCurso = () => {
if (!nuevoCurso.nombre.trim()) return;
setCursos(cs => […cs, { id:Date.now(), nombre:nuevoCurso.nombre.trim(), sigla:””, profesor:””, creditos:””, color:nuevoCurso.color }]);
const idx = COLORES.indexOf(nuevoCurso.color);
setNuevoCurso({ nombre:””, color:COLORES[(idx+1)%COLORES.length] });
};

const siguiente = () => {
setErr(””);
if (paso===1) {
if (diasSel.length===0) { setErr(“Selecciona al menos un día de clase”); return; }
setPaso(2);
} else if (paso===2) {
if (mismoHorario && horaGlobal.ini>=horaGlobal.fin) { setErr(“La hora de salida debe ser mayor a la de entrada”); return; }
const diaInvalido = !mismoHorario && diasSel.find(d => (horPorDia[d]?.ini||“08:00”) >= (horPorDia[d]?.fin||“13:00”));
if (diaInvalido) { setErr(“Revisa que la hora fin sea mayor al inicio en todos los días”); return; }
setPaso(3);
} else {
const horEfectivo: Record<number,any> = {};
diasSel.forEach(d => { horEfectivo[d] = getHEfectivo(d); });
const iniRef = mismoHorario ? horaGlobal.ini : (horPorDia[diasSel[0]]?.ini||“08:00”);
onDone({ diasClase:diasSel, turno:getTurno(iniRef), mismoHorario, horaGlobal,
horarioPorDia:horEfectivo, horarioConfigurado:true, cursos, horario:[], tareas:[] });
}
};

const pct = Math.round((paso/3)*100);

return (
<div style={{ maxWidth:“400px”, width:“100%” }}>
<div style={{ marginBottom:“20px” }}>
<div style={{ display:“flex”, justifyContent:“space-between”, marginBottom:“6px” }}>
<span style={{ color: m.textMuted, fontSize:“0.74em” }}>Paso {paso} de 3</span>
<span style={{ color:t.a, fontSize:“0.74em”, fontWeight:“bold” }}>{pct}%</span>
</div>
<div style={{ background: m.progressBg, borderRadius:“10px”, height:“5px” }}>
<div style={{ background:`linear-gradient(90deg,${t.a},${t.b})`, borderRadius:“10px”, height:“5px”, width:`${pct}%`, transition:“width 0.35s ease” }} />
</div>
<div style={{ display:“flex”, justifyContent:“space-between”, marginTop:“5px” }}>
{[“📅 Días”,“🕐 Horario”,“📚 Cursos”].map((l,i) => (
<span key={i} style={{ fontSize:“0.62em”, color: paso>i?t.a:m.textVeryFaint, fontWeight: paso===i+1?“bold”:“normal” }}>{l}</span>
))}
</div>
</div>

