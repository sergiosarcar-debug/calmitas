function Auth({ onLogin, t }: any) {
const m = useM();
const [modo, setModo] = useState(“welcome”);
const [form, setForm] = useState({ email:””, pass:””, pass2:”” });
const [err,  setErr]  = useState(””);

const setField = (k: string, v: string) => { setForm(f => ({ …f, [k]: v })); setErr(””); };

const handleLogin = () => {
if (!form.email.includes(”@”)) { setErr(“Ingresa un correo válido”); return; }
if (!form.pass)                 { setErr(“Ingresa tu contraseña”); return; }
const emailKey = form.email.toLowerCase().trim();
const acc = getAccount(emailKey);
if (!acc)          { setErr(“No encontramos esa cuenta. ¿Quieres registrarte?”); return; }
if (!acc.password) { setErr(“Error en cuenta. Crea una cuenta nueva.”); return; }
if (acc.password !== form.pass) { setErr(“Contraseña incorrecta. Inténtalo de nuevo.”); return; }
onLogin(emailKey, acc);
};

const handleRegistro = () => {
if (!form.email.includes(”@”))    { setErr(“Ingresa un correo válido”); return; }
if (form.pass.length < 6)         { setErr(“La contraseña debe tener al menos 6 caracteres”); return; }
if (form.pass !== form.pass2)     { setErr(“Las contraseñas no coinciden”); return; }
const emailKey = form.email.toLowerCase().trim();
if (accountExists(emailKey))      { setErr(“Ya existe una cuenta con ese correo”); return; }
const newAcc = initUserState({ email: emailKey });
(newAcc as any).password = form.pass;
saveAccount(emailKey, newAcc);
onLogin(emailKey, newAcc);
};

const ErrorMsg = () => err ? <p style={{ color:”#f87171”, fontSize:“0.82em”, textAlign:“center”, marginBottom:“12px” }}>{err}</p> : null;

if (modo === “welcome”) return (
<div style={{ textAlign:“center”, maxWidth:“380px”, width:“100%” }}>
<div style={{ fontSize:“80px”, marginBottom:“10px” }}>🤲</div>
<h1 style={{ fontSize:“2.8em”, fontWeight:“900”, margin:“0 0 8px”,
background:`linear-gradient(90deg,${t.a},${t.b})`,
WebkitBackgroundClip:“text”, WebkitTextFillColor:“transparent” }}>Calmitas</h1>
<p style={{ color: m.textMuted, fontSize:“0.9em”, margin:“0 0 32px” }}>Tu compañero antiestrés universitario 🤲</p>
<div style={{ display:“flex”, flexDirection:“column”, gap:“12px” }}>
<Btn onClick={() => setModo(“registro”)} t={t}>Crear mi cuenta 🚀</Btn>
<Btn variant=“ghost” onClick={() => setModo(“login”)} t={t}>Ya tengo cuenta →</Btn>
<div style={{ position:“relative”, margin:“4px 0” }}>
<div style={{ borderTop:`1px solid ${m.divider}`, position:“absolute”, top:“50%”, left:0, right:0 }} />
<span style={{ position:“relative”, padding:“0 10px”, color: m.textVeryFaint, fontSize:“0.72em” }}>o</span>
</div>
<button onClick={() => onLogin(”**invitado**”, null)}
style={{ background:“transparent”, border:`1px dashed ${m.textVeryFaint}`,
borderRadius:“30px”, padding:“12px 20px”, color: m.textFaint, fontSize:“0.88em”, cursor:“pointer” }}>
👀 Explorar sin cuenta
<div style={{ fontSize:“0.72em”, color: m.textVeryFaint, marginTop:“2px” }}>Sin guardar progreso · acceso limitado</div>
</button>
</div>
<p style={{ color: m.textVeryFaint, fontSize:“0.62em”, marginTop:“28px” }}>UTP Lima Norte · Grupo 05 · 2026</p>
</div>
);

if (modo === “login”) return (
<div style={{ maxWidth:“380px”, width:“100%” }}>
<BackBtn onClick={() => setModo(“welcome”)} />
<PageTitle sub="Ingresa con tu correo y contraseña">👋 Bienvenido de vuelta</PageTitle>
<div style={{ display:“flex”, flexDirection:“column”, gap:“10px”, marginBottom:“16px” }}>
<div><p style={{ margin:“0 0 6px”, fontSize:“0.8em”, color: m.textMuted }}>Correo electrónico</p>
<Input placeholder=“tucorreo@gmail.com” value={form.email} onChange={(e: any) => setField(“email”, e.target.value)} type=“email” /></div>
<div><p style={{ margin:“0 0 6px”, fontSize:“0.8em”, color: m.textMuted }}>Contraseña</p>
<Input placeholder=“Tu contraseña” value={form.pass} onChange={(e: any) => setField(“pass”, e.target.value)} type=“password” /></div>
</div>
<ErrorMsg />
<Btn onClick={handleLogin} t={t}>Ingresar →</Btn>
<p style={{ textAlign:“center”, marginTop:“16px”, fontSize:“0.82em”, color: m.textMuted }}>
¿No tienes cuenta? <span onClick={() => setModo(“registro”)} style={{ color:t.a, cursor:“pointer”, fontWeight:“bold” }}>Regístrate</span>
