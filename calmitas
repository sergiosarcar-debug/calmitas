function OrgUni({ state, dispatch, t, onBack, onRecompensa }: any) {
const m = useM();
const { orgUni } = state;
const [vista, setVista] = useState(“main”);
const [org, setOrg] = useState(() => ({
cursos:  orgUni?.cursos  || [],
horario: orgUni?.horario || [],
tareas:  orgUni?.tareas  || [],
diasClase:          orgUni?.diasClase          || [],
horarioConfigurado: orgUni?.horarioConfigurado || false,
mismoHorario:       orgUni?.mismoHorario       ?? true,
horaGlobal:         orgUni?.horaGlobal         || {ini:“08:00”,fin:“13:00”},
horarioPorDia:      orgUni?.horarioPorDia      || {},
turno:              orgUni?.turno              || “manana”,
}));
const [nuevoCurso, setNuevoCurso] = useState({nombre:””,sigla:””,profesor:””,color:”#a78bfa”,creditos:””});
const [nuevaTarea, setNuevaTarea] = useState({titulo:””,cursoId:””,tipo:“tarea”,fecha:””,prioridad:“media”,notas:””});
const [filtro, setFiltro] = useState(“pendientes”);
const [bloqueEdit, setBloqueEdit] = useState(null as any);

const COLORES_CURSO = [”#a78bfa”,”#60a5fa”,”#34d399”,”#f59e0b”,”#f472b6”,”#fb923c”,”#38bdf8”,”#818cf8”];
const HORAS_TABLA = [“07:00”,“08:00”,“09:00”,“10:00”,“11:00”,“12:00”,“13:00”,“14:00”,“15:00”,“16:00”,“17:00”,“18:00”,“19:00”,“20:00”,“21:00”];
const TIPO_ICON: Record<string,string> = {tarea:“📝”,examen:“📋”,proyecto:“🚀”,lectura:“📖”,otro:“📌”};

const guardar = (nuevoCampos: any) => {
const nuevo = {…org,…nuevoCampos};
setOrg(nuevo);
dispatch({type:“SET_ORG_UNI”,data:nuevo});
if (!orgUni) onRecompensa(“planificador”);
if (nuevo.horario?.length>0) onRecompensa(“universitario”);
};

const addCurso = () => {
if (!nuevoCurso.nombre.trim()) return;
const c = {…nuevoCurso,id:Date.now()};
guardar({cursos:[…org.cursos,c]});
setNuevoCurso({nombre:””,sigla:””,profesor:””,color:COLORES_CURSO[org.cursos.length%COLORES_CURSO.length],creditos:””});
setVista(“cursos”);
};
const delCurso = (id: number) => guardar({cursos:org.cursos.filter((c: any)=>c.id!==id),horario:org.horario.filter((h: any)=>h.cursoId!==id),tareas:org.tareas.filter((ta: any)=>ta.cursoId!==id)});
const setBloque = (dia: number, hora: string, cursoId: any) => {
const nuevo = org.horario.filter((h: any)=>!(h.dia===dia&&h.hora===hora));
if (cursoId) nuevo.push({dia,hora,cursoId});
guardar({horario:nuevo});
};
const getCursoEnBloque = (dia: number, hora: string) => {
const b = org.horario.find((h: any)=>h.dia===dia&&h.hora===hora);
return b ? org.cursos.find((c: any)=>c.id===b.cursoId) : null;
};
const addTarea = () => {
if (!nuevaTarea.titulo.trim()) return;
guardar({tareas:[…org.tareas,{…nuevaTarea,id:Date.now(),completada:false}]});
setNuevaTarea({titulo:””,cursoId:””,tipo:“tarea”,fecha:””,prioridad:“media”,notas:””});
setVista(“tareas”);
};
const toggleTarea = (id: number) => guardar({tareas:org.tareas.map((ta: any)=>ta.id===id?{…ta,completada:!ta.completada}:ta)});
const delTarea   = (id: number) => guardar({tareas:org.tareas.filter((ta: any)=>ta.id!==id)});

const hoy = new Date().toISOString().split(“T”)[0];
const diaHoy = new Date().getDay();
const tareasFiltradas = org.tareas.filter((ta: any) => {
if (filtro===“pendientes”)  return !ta.completada;
if (filtro===“hoy”)         return ta.fecha===hoy&&!ta.completada;
if (filtro===“examen”)      return ta.tipo===“examen”&&!ta.completada;
if (filtro===“completadas”) return ta.completada;
return true;
});
const tareasUrgentes = org.tareas.filter((ta: any) => {
if (ta.completada||!ta.fecha) return false;
const d=new Date(ta.fecha+“T00:00:00”),h=new Date(); h.setHours(0,0,0,0);
return Math.ceil((d.getTime()-h.getTime())/(1000*60*60*24))<=3;
});
const clasesHoy = HORAS_TABLA.map(h=>({hora:h,curso:getCursoEnBloque(diaHoy,h)})).filter(x=>x.curso);

if (vista===“horario”) return (
<div style={{ maxWidth:“420px”, width:“100%” }}>
<BackBtn onClick={() => setVista(“main”)} />
<PageTitle sub="Toca un bloque para asignar un curso">📆 Horario semanal</PageTitle>
{org.cursos.length===0 ? (
<Card style={{ textAlign:“center”, padding:“20px”, marginBottom:“14px” }}>
<p style={{ margin:0, color: m.textMuted, fontSize:“0.85em” }}>Primero agrega tus cursos para armar el horario</p>
