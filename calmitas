const initUserState = (saved: any) => ({
perfil:       saved?.perfil       || null,
historial:    saved?.historial    || [],
puntos:       saved?.puntos       || 0,
insignias:    saved?.insignias    || [],
retos:        saved?.retos        || [],
calmitasUsos: saved?.calmitasUsos || 0,
temaId:       saved?.temaId       || “morado”,
modoOscuro:   saved?.modoOscuro   ?? true,   // ← modo claro/oscuro
orgUni:       saved?.orgUni       || null,
email:        saved?.email        || “”,
});

function appReducer(state: any, action: any) {
switch (action.type) {
case “SET_PERFIL”:      return { …state, perfil: action.perfil };
case “ADD_HISTORIAL”:   return { …state, historial: […state.historial, action.entry] };
case “COMPLETAR_RETO”:
if (state.retos.includes(action.id)) return state;
return { …state, retos: […state.retos, action.id], puntos: state.puntos + 15 };
case “ADD_INSIGNIA”: {
if (state.insignias.includes(action.id)) return state;
const ins = INSIGNIAS_DB.find(x => x.id === action.id);
return { …state, insignias: […state.insignias, action.id], puntos: state.puntos + (ins?.pts || 0) };
}
case “SET_CALMITAS”:  return { …state, calmitasUsos: action.usos };
case “SET_TEMA”:      return { …state, temaId: action.id };
case “SET_MODO”:      return { …state, modoOscuro: action.dark };   // ← nuevo
case “SET_AVATAR”:    return { …state, perfil: { …state.perfil, avatar: action.avatar } };
case “TOGGLE_CAUSA”: {
if (!state.perfil) return state;
const causas = state.perfil.causas.includes(action.id)
? state.perfil.causas.filter((c: number) => c !== action.id)
: […state.perfil.causas, action.id];
if (causas.length === 0) return state;
return { …state, perfil: { …state.perfil, causas } };
}
case “SET_ORG_UNI”:  return { …state, orgUni: action.data };
default:             return state;
}
}

