) : (
<>
<div style={{ display:“flex”, gap:“6px”, marginBottom:“14px”, flexWrap:“wrap” }}>
{org.cursos.map((c: any) => <span key={c.id} style={{ background:`${c.color}22`, border:`1px solid ${c.color}55`,
borderRadius:“20px”, padding:“4px 10px”, fontSize:“0.72em”, color:c.color, fontWeight:“bold” }}>{c.sigla||c.nombre.substring(0,6)}</span>)}
</div>
