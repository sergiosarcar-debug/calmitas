const getAllAccounts = () => {
try { const raw = localStorage.getItem(DB_KEY); return raw ? JSON.parse(raw) : {}; }
catch { return {}; }
};
const saveAccount = (email: string, data: any) => {
try { const all = getAllAccounts(); all[email] = data; localStorage.setItem(DB_KEY, JSON.stringify(all)); }
catch { console.warn(”[Calmitas] No se pudo guardar en localStorage.”); }
};
const getAccount    = (email: string) => getAllAccounts()[email] || null;
const accountExists = (email: string) => !!getAccount(email);

