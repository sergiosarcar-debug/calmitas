<ModeCtx.Provider value={m}>
<div style={{ minHeight:“100vh”, background: m.bg, fontFamily:”-apple-system,BlinkMacSystemFont,‘Segoe UI’,Arial,sans-serif”, color: m.text, transition:“background 0.4s, color 0.3s” }}>
{popup && <RecompensaPopup ins={popup} onClose={()=>setPopup(null)} />}

